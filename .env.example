# Copy this file to `.env` and fill in real values (or set these as environment
# variables on your host). `.env` is gitignored, so your real secrets never
# reach the repository. All of these are optional — the app runs without them,
# but invoices need a real IBAN and a fresh deploy needs admin credentials.

# --- Payment details shown on invoices ---
PAYMENT_IBAN=FI00 0000 0000 0000 00
PAYMENT_PAYEE=Your Business Name
# Optional: a MobilePay number to also accept mobile payments (leave blank to skip)
PAYMENT_MOBILEPAY=+358 40 000 0000

# --- Initial admin + coach (Kalle) logins, created on the very first run ---
# If an ADMIN_PASSWORD / COACH_PASSWORD is not set, a strong random password is
# generated and printed to the server log once — grab it from there.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=choose-a-strong-password
COACH_EMAIL=coach@example.com
COACH_PASSWORD=choose-a-strong-password

# --- Optional: real invoice emails via any SMTP provider ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Proballers Coaching <no-reply@yourdomain.fi>"

# --- Optional: Google Sheets sync (service account) ---
# GOOGLE_SERVICE_ACCOUNT=/path/to/service-account.json
# GOOGLE_SHEET_ID=
